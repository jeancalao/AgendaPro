# ========================
# BANCO DE DADOS
# ========================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/agendapro?schema=public"

# ========================
# SUPABASE AUTH (backend — apps/api/.env)
# ========================
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ========================
# SUPABASE AUTH (frontend — apps/web/.env)
# prefixo VITE_ obrigatório para o Vite expor as variáveis
# ========================
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# ========================
# STRIPE (Pagamentos)
# ========================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ========================
# RESEND (E-mail)
# ========================
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@agendapro.com.br"

# ========================
# Z-API (WhatsApp)
# ========================
ZAPI_INSTANCE_ID="your-instance-id"
ZAPI_TOKEN="your-token"

# ========================
# APP
# ========================
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:5173"
